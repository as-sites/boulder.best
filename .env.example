# Copy this file to .env and fill in the values.
# mise loads .env automatically — all mise tasks (including db:*) inherit these vars.

# Wrangler deploy/dev and `mise run secrets:sync:github` (optional if you use `wrangler login` instead).
# CLOUDFLARE_ACCOUNT_ID=
# CLOUDFLARE_API_TOKEN=
# Zone ID for boulder.best (dashboard zone overview); used by `mise run api:r2:domain:*`.
# CLOUDFLARE_ZONE_ID=

# R2 S3 API credentials for presigned browser uploads (Dashboard > R2 > Manage R2 API tokens).
R2_ACCOUNT_ID= # usually the same value as CLOUDFLARE_ACCOUNT_ID.
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# Required for all Drizzle migration tasks (db:generate, db:migrate, db:check, db:push, db:studio).
# Use your Neon project connection string (pooled or direct; direct is recommended for migrations).
# Format: postgresql://<user>:<password>@<host>/<dbname>?sslmode=require
DATABASE_URL=

# Required for local Cloudflare Worker dev (wrangler dev / api:dev).
# Place secrets here instead of wrangler.jsonc to keep them out of source control.
# See apps/api/wrangler.jsonc for the non-secret vars that are already committed.
BETTER_AUTH_SECRET=

# Optional — only needed when the corresponding feature is enabled.
# Password-reset emails (better-auth emailAndPassword.sendResetPassword).
# RESEND_API_KEY=

# OAuth providers (better-auth socialProviders).
# Register these Better Auth redirect URLs with the providers:
# - Google:  https://boulder.best/api/auth/callback/google
# - Discord: https://boulder.best/api/auth/callback/discord
# For local API dev, use the same path on your local BETTER_AUTH_URL.
# Each provider requires both its ID and secret when enabled.
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# DISCORD_CLIENT_ID=
# DISCORD_CLIENT_SECRET=

# Optional — Sentry (omit locally to disable reporting / source map uploads).
# Frontend bundle (VITE_* are exposed to the browser build):
# VITE_SENTRY_DSN_FRONTEND=
# VITE_SENTRY_RELEASE_FRONTEND=   # CI sets this to the deploy commit SHA
# Shared — source map uploads for frontend:build and api:sentry:sourcemaps:
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=
# SENTRY_PROJECT_FRONTEND=
# SENTRY_PROJECT_API=
# API Worker runtime (wrangler secret for production):
# SENTRY_DSN_API=

# Passkeys (better-auth passkey plugin).
# PASSKEY_RP_ID is a domain-style relying party ID, not a URL.
# PASSKEY_ORIGIN defaults to BETTER_AUTH_URL when omitted and must not end with "/".
# PASSKEY_RP_ID=boulder.best
# PASSKEY_ORIGIN=https://boulder.best
