amends "package://github.com/jdx/hk/releases/download/v1.46.0/hk@1.46.0#/Config.pkl"
import "package://github.com/jdx/hk/releases/download/v1.46.0/hk@1.46.0#/Builtins.pkl"

local linters = new Mapping<String, Step> {
    ["check-merge-conflict"] = Builtins.check_merge_conflict
    ["oxlint"] = (Builtins.ox_lint) {
        check = "oxlint --format=stylish {{ files }}"
    }
    ["oxfmt"] = Builtins.oxfmt
}

hooks {
    ["pre-commit"] {
        fix = true
        stash = "git"
        steps = linters
    }
    ["fix"] {
        fix = true
        steps = linters
    }
    ["check"] {
        steps = linters
    }
}