          },
          "401": {
            "description": "Unauthorized",
          },
        },
        "security": [
          {
            "sessionCookie": [],
          },
        ],
        "summary": "Create presigned R2 upload URL",
        "tags": [
          "Uploads",
        ],
      },
    },
  },
  "tags": [
    {
      "description": "Read-only gym catalog",
      "name": "Gyms",
    },
    {
      "description": "Authenticated R2 presigned uploads",
