                },
              },
            },
            "description": "Session detail",
          },
          "401": {
            "description": "Unauthorized",
          },
          "404": {
            "description": "Session not found",
          },
        },
        "security": [
          {
            "sessionCookie": [],
          },
        ],
        "summary": "Get session detail",
        "tags": [
          "Sessions",
        ],
      },
    },
    "/api/uploads/presigned-url": {
      "post": {
        "description": "Returns a temporary upload URL and final image metadata for a client-side Dexie image blob.",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PresignedUploadRequest",
