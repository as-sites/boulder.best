  "info": {
    "description": "Offline-first bouldering tracker MVP API contract shared between frontend and worker.",
    "title": "Boulder Best API",
    "version": "0.0.0",
  },
  "openapi": "3.0.0",
  "paths": {
    "/api/gyms": {
      "get": {
        "description": "Returns the read-only gym catalog with grade scales for online use and offline cache hydration.",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GymsResponse",
                },
              },
            },
            "description": "Available gyms",
          },
          "429": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiErrorResponse",
                },
              },
            },
            "description": "Too many requests",
          },
        },
        "summary": "List gyms",
        "tags": [
          "Gyms",
        ],
      },
    },
    "/api/sessions": {
      "get": {
        "description": "Returns paginated session summaries for the authenticated user, newest first by startTime.",
        "parameters": [
          {
            "in": "query",
            "name": "limit",
            "required": false,
            "schema": {
              "default": 20,
              "maximum": 50,
              "minimum": 1,
              "type": "integer",
            },
          },
          {
            "description": "Keyset pagination cursor from the previous page nextCursor (startTime + id tie-breaker)",
            "in": "query",
            "name": "cursor",
            "required": false,
            "schema": {
              "allOf": [
                {
                  "$ref": "#/components/schemas/SessionHistoryCursor",
                },
                {
                  "description": "Keyset pagination cursor from the previous page nextCursor (startTime + id tie-breaker)",
                },
              ],
            },
          },
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SessionHistoryListResponse",
                },
              },
            },
            "description": "Paginated session history",
          },
          "401": {
            "description": "Unauthorized",
          },
        },
        "security": [
          {
            "sessionCookie": [],
          },
        ],
        "summary": "List session history",
        "tags": [
          "Sessions",
        ],
      },
    },
    "/api/sessions/sync": {
      "post": {
        "description": "Upserts a completed session payload from the offline sync queue for the authenticated user.",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SyncSessionPayload",
              },
            },
          },
          "required": true,
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SyncSessionSuccessResponse",
                },
              },
            },
            "description": "Session synced successfully",
          },
          "400": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiErrorResponse",
                },
              },
            },
            "description": "Validation error",
          },
          "401": {
            "description": "Unauthorized",
          },
        },
        "security": [
          {
            "sessionCookie": [],
          },
        ],
        "summary": "Sync an offline session",
        "tags": [
          "Sessions",
        ],
      },
    },
    "/api/sessions/{id}": {
      "get": {
        "description": "Returns a single session with entries ordered by sequenceOrder and climb images ordered by index.",
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "schema": {
              "example": "987fcdeb-51a2-43d7-9012-345678901234",
              "format": "uuid",
              "type": "string",
            },
          },
        ],
        "responses": {
